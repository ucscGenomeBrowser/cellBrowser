def main():
    parser = argparse.ArgumentParser(
        description="Extract author emails from bioRxiv/medRxiv preprints or PubMed articles "
                    "and send outreach emails about the UCSC Cell Browser.")
    parser.add_argument("identifier", nargs="?",
                        help="A bioRxiv/medRxiv DOI or a PubMed ID (PMID)")
    parser.add_argument("emails", nargs="*", help="Email addresses (skips the email search step)")
    parser.add_argument("--name", dest="dataset_name",
                        help="Dataset name to use. Skips Claude-based name generation.")
    parser.add_argument("--scanPre", nargs="?", const="today", metavar="DATE",
                        help="Scan bioRxiv/medRxiv for single-cell papers. "
                             "No date=today, one date=that day, or START/END for a range "
                             "(e.g. 2026-04-01/2026-04-09).")
    parser.add_argument("--scanPm", nargs="?", const="today", metavar="DATE",
                        help="Scan PubMed for single-cell papers. "
                             "Same date syntax as --scanPre.")
    parser.add_argument("--query", default="single cell",
                        help="Pre-filter keyword for --scanPre/--scanPm (default: 'single cell')")
    args = parser.parse_args()

    # Check for API key
    if not os.environ.get("ANTHROPIC_API_KEY"):
        print("Error: ANTHROPIC_API_KEY environment variable not set", file=sys.stderr)
        sys.exit(1)

    # Scan modes
    for scan_arg, scan_fn in [(args.scanPre, scan_biorxiv), (args.scanPm, scan_pubmed)]:
        if scan_arg is not None:
            if scan_arg == "today":
                scan_fn(query=args.query)
            elif "/" in scan_arg:
                parts = scan_arg.split("/")
                if len(parts) != 2:
                    parser.error("Date range must be START/END, e.g. 2026-04-01/2026-04-09")
                scan_fn(start_date=parts[0], end_date=parts[1], query=args.query)
            else:
                scan_fn(start_date=scan_arg, query=args.query)
            return

    if not args.identifier:
        parser.error("identifier is required (unless using --scanPre or --scanPm)")

    identifier = args.identifier.strip()
    provided_emails = [e.strip() for e in args.emails if e.strip()]
    dataset_name = args.dataset_name

    if "doi.org" in identifier:
        # https://doi.org/10.64898/2026.03.09.710568
        identifier = identifier.replace("https://doi.org/", "")

    # Step 1: Get metadata (from PubMed for PMID, from bioRxiv for DOI)
    is_pmid_input = is_pmid(identifier)

    if is_pmid_input:
        print(f"PMID detected: {identifier}")
        print("Fetching metadata from PubMed...")
        try:
            record = get_pubmed_record(identifier)
        except Exception as e:
            print(f"Error: Could not fetch PubMed metadata: {e}", file=sys.stderr)
            sys.exit(1)
    else:
        print(f"DOI detected: {identifier}")
        print("Fetching metadata from bioRxiv/medRxiv...")
        try:
            record = get_biorxiv_record(identifier)
        except Exception as e:
            print(f"Error: Could not fetch bioRxiv metadata: {e}", file=sys.stderr)
            sys.exit(1)

    authors_str = record.get("authors", "")
    corr_inst = record.get("author_corresponding_institution")
    paper_title = record.get("title", "")

    if not authors_str:
        print("Error: No authors found in metadata", file=sys.stderr)
        sys.exit(1)

    if "author_corresponding" in record and record["author_corresponding"]:
        authors = [record["author_corresponding"]]
    else:
        authors = parse_authors(authors_str)

    print(f"Paper: {paper_title[:80]}...")
    print(f"Institution: {corr_inst or 'Unknown'}")
    if len(authors) >= 2:
        print(f"First author: {authors[0]}")
        print(f"Last author: {authors[-1]}")
    else:
        print(f"Author: {authors[0]}")

    # Step 2: Get email addresses
    if provided_emails:
        # Use provided email addresses
        print(f"\nUsing provided email addresses:")
        for email in provided_emails:
