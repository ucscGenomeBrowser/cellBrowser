BIO_RXIV_API = "https://api.biorxiv.org/details/biorxiv"
MEDRXIV_API = "https://api.biorxiv.org/details/medrxiv"
NCBI_EFETCH_URL = "https://eutils.ncbi.nlm.nih.gov/entrez/eutils/efetch.fcgi"


def is_pmid(identifier: str) -> bool:
    """
    Check if the identifier is a PMID (purely numeric) or a DOI.
    PMIDs are numeric strings, DOIs typically start with "10."
    """
    return identifier.isdigit()


def get_pubmed_record(pmid: str) -> dict:
    """
    Get paper metadata directly from PubMed using NCBI E-utilities API.
    Returns a dict with keys similar to bioRxiv API response:
    - title, abstract, authors, author_corresponding_institution, date, doi
    - author_corresponding (last author name)
    - corresponding_email (if found in affiliations)
    """
    params = {
        "db": "pubmed",
        "id": pmid,
        "retmode": "xml"
    }
    resp = requests.get(NCBI_EFETCH_URL, params=params, timeout=30)
    if resp.status_code != 200:
        raise RuntimeError(f"NCBI API returned status {resp.status_code}")

    root = ET.fromstring(resp.text)

    # Get title
    title_elem = root.find(".//ArticleTitle")
    title = title_elem.text if title_elem is not None else ""

    # Get abstract
    abstract_elem = root.find(".//AbstractText")
    abstract = abstract_elem.text if abstract_elem is not None else ""

    # Get DOI if available
    doi = ""
    for article_id in root.findall(".//ArticleId"):
        if article_id.get("IdType") == "doi":
            doi = article_id.text
            break
    if not doi:
        for eloc in root.findall(".//ELocationID"):
            if eloc.get("EIdType") == "doi":
                doi = eloc.text
                break

    # Get publication date
    pub_date = root.find(".//PubDate")
    date = ""
    if pub_date is not None:
        year = pub_date.find("Year")
        month = pub_date.find("Month")
        day = pub_date.find("Day")
        date_parts = []
        if year is not None:
            date_parts.append(year.text)
        if month is not None:
            date_parts.append(month.text)
        if day is not None:
            date_parts.append(day.text)
        date = "-".join(date_parts)

    # Get authors and affiliations
    authors_list = []
    corresponding_email = None
    institution = ""

    for author in root.findall(".//Author"):
        last_name = author.find("LastName")
        fore_name = author.find("ForeName")
        initials = author.find("Initials")

        if last_name is not None:
            if fore_name is not None:
                name = f"{fore_name.text} {last_name.text}"
            elif initials is not None:
                name = f"{initials.text} {last_name.text}"
            else:
                name = last_name.text
            authors_list.append(name)

        # Check affiliations for email addresses
        for affil in author.findall(".//AffiliationInfo/Affiliation"):
            if affil.text:
                # Extract email if present (often at end of affiliation)
                email_match = re.search(r'[\w.+-]+@[\w.-]+\.\w+', affil.text)
                if email_match:
                    corresponding_email = email_match.group(0)
                # Use first affiliation as institution
                if not institution:
                    # Remove email from institution string if present
                    inst_text = re.sub(r'\s*[\w.+-]+@[\w.-]+\.\w+\.?\s*$', '', affil.text)
                    institution = inst_text.strip().rstrip('.')

    # Format authors string like bioRxiv does: "Last1, F.; Last2, F. M."
    authors_str = "; ".join(authors_list)

    # Last author is typically the corresponding author
    author_corresponding = authors_list[-1] if authors_list else ""

    return {
        "title": title,
        "abstract": abstract,
        "authors": authors_str,
        "author_corresponding": author_corresponding,
        "author_corresponding_institution": institution,
        "date": date,
        "doi": doi,
        "corresponding_email": corresponding_email,
        "category": ""  # PubMed doesn't have this field
    }


def parse_authors(authors_str: str) -> list:
    """
    Parse the authors string from bioRxiv API into a list of full names.
    Input format: "Last1, F.; Last2, F. M.; Last3, F."
    Output: ["F. Last1", "F. M. Last2", "F. Last3"]
    """
    authors = []
    for author in authors_str.split(";"):
        author = author.strip()
        if not author:
            continue
        # Format is "LastName, Initials"
        if "," in author:
            parts = author.split(",", 1)
            last_name = parts[0].strip()
            initials = parts[1].strip() if len(parts) > 1 else ""
            # Reconstruct as "Initials LastName"
            if initials:
                authors.append(f"{initials} {last_name}")
            else:
                authors.append(last_name)
        else:
            authors.append(author)
    return authors


def get_biorxiv_record(doi: str) -> dict:
    """
    Query the bioRxiv/medRxiv API for a single DOI and return the first record.
    """
    doi_encoded = quote(doi, safe="/")

    # Try bioRxiv first, then medRxiv
    for api_url in [BIO_RXIV_API, MEDRXIV_API]:
        url = f"{api_url}/{doi_encoded}/na/json"
        resp = requests.get(url, timeout=30)
        if resp.status_code == 200:
            data = resp.json()
            collection = data.get("collection", [])
            if collection:
                return collection[0]

    raise RuntimeError(f"No records found for DOI {doi}")


def find_emails_with_claude(authors: list, institution: str) -> dict:
    """
    Use Claude API with web search to find email addresses for first and last authors.
    Returns a dict mapping author names to their email addresses.
    Includes retry logic for rate limit errors.
    """
    client = anthropic.Anthropic()

    # Only search for first and last author
    if len(authors) >= 2:
        search_authors = [authors[0], authors[-1]]
    else:
        search_authors = authors

    authors_list = "\n".join(f"- {name}" for name in search_authors)

    prompt = f"""Find email addresses for these researchers at {institution}:

{authors_list}

Search the institution's website for faculty profile pages, lab websites, or directory listings that show their contact emails.

IMPORTANT: Your response must contain ONLY lines in this exact format, with no other text, explanations, or commentary:
AUTHOR_NAME: email@example.com

If you cannot find an email for an author, output:
AUTHOR_NAME: NOT_FOUND

Example correct output (use actual names and emails found):
John Smith: john.smith@university.edu
Jane Doe: NOT_FOUND

Do not include any other text besides lines in the above format.
"""

    # Retry loop for rate limits
    for attempt in range(MAX_RETRIES):
        try:
            response = client.messages.create(
                model="claude-sonnet-4-20250514",
                max_tokens=4096,
                tools=[{"type": "web_search_20250305", "name": "web_search", "max_uses": 10}],
                messages=[{"role": "user", "content": prompt}]
            )
            break  # Success, exit retry loop
        except anthropic.RateLimitError as e:
            if attempt < MAX_RETRIES - 1:
                print(f"Rate limited, waiting {RETRY_DELAY}s before retry {attempt + 2}/{MAX_RETRIES}...")
                time.sleep(RETRY_DELAY)
            else:
                raise  # Re-raise on final attempt

    # Parse the response to extract author-email pairs
    results = {}
    for block in response.content:
        if block.type == "text":
            text = block.text
            # Look for lines with "name: email" pattern
            for line in text.split("\n"):
                # Try to match "Name: email@domain.com" pattern
                # Name should be just letters, dots, spaces, hyphens (typical author name format)
                match = re.match(r'^[*-]?\s*([A-Za-z][A-Za-z.\-\s]{1,50}):\s*([\w.+-]+@[\w.-]+\.\w+|NOT_FOUND)\s*$', line.strip())
                if match:
                    name = match.group(1).strip()
                    email = match.group(2)
                    if email != "NOT_FOUND":
                        results[name] = email

    return results


def personalize_email_with_claude(template: str, record: dict, recipient_name: str) -> dict:
    """
    Use Claude to personalize the email template based on paper metadata.
    Returns dict with 'subject' and 'body' keys.
    Uses Haiku for speed and lower rate limits.
    Includes retry logic for rate limit errors.
    """
    client = anthropic.Anthropic()

    title = record.get("title", "")
    abstract = record.get("abstract", "")
    doi = record.get("doi", "")
    institution = record.get("author_corresponding_institution", "")
    authors = record.get("authors", "")
    category = record.get("category", "")
    date = record.get("date", "")

    path = "/hive/data/inside/cells/datasets"
    dsNames = [name for name in os.listdir(path) if os.path.isdir(os.path.join(path, name))]
    dsNameString = ",".join(dsNames)

    paper_url = f"https://doi.org/{doi}" if doi else ""

    prompt = f"""You are helping to personalize an outreach email to a researcher about their preprint.

Here is information about the paper:
- Title: {title}
- Authors: {authors}
- Institution: {institution}
- Category: {category}
- Date: {date}
- DOI: {doi}
- Paper URL: {paper_url}
- Abstract: {abstract}

The recipient is: {recipient_name}
(Use only their first name in the greeting, e.g., "Dear John," not "Dear Dr. Smith,")

Here is the email template to personalize:
---
{template}
---

Please rewrite this email to make it specific to this paper. Reference specific aspects of their research (from the title/abstract) without praising the work, no sycophancy please. Keep the same overall structure and style of the template.

Replace $DATASET_NAME with a suggested shortname of the dataset. A good dataset shortname is shorter than 25 characters. Never include the word "human", as most datasets are human. Never include "singlecell" or "sc" into the name, as all datasets are from single cells. The name usually includes the organ and the disease, the most important one of the paper,
or the cell line or condition that the paper focusses on. If the paper has mostly ATAC or spatial data, add -atac or -spatial to the dataset name. You can add the celltype if the paper focuses on a celltype. Abbreviate parts of the name to shorten the name if necessary. Only dashes are allowed in the name and lowercase characters. Example dataset names are: cortex-dev for a paper about the developing cortex, cortex-atac, for ATAC-seq on the cortex. Other examples: mouse-liver-scaring, ciona-regeneration, zebrafish-dev, hindbrain-dev, mouse-olig-dev. ms is usually multiple sclerosis, common acronyms for diseases are fine to use as acronyms. We do not usually abbreviate "organoid", so leave that as a word. Use an acronym if possible from the abstract, e.g. if the abstract mentions "HSC" as hematopoietic stem cells, then create a dataset with that acronym it, e.g. hsc-reprogram.
Try to use one or two parts separated by dashes, and not to use more than three parts separated by dashes. If the dataset is from mouse or another non-human species, prefix the dataset with the name of the species.

Here are example dataset names, as examples, do not use any of these literally, to avoid conflicts, but use them as inspiration: {dsNameString}

Do not use these words in dataset names:
    - homo
    - hetero

If the abstract suggests that the paper contains ATAC-seq or Chip-Seq or "chromatin accessibility" data or other cis-regulatory data, replace the placeholder "UCSC Genome Browser tracks note for ATAC-seq datasets" with a text like the following: "Since your paper seems to include Chip-Seq or ATAC-seq data, note that we have support for this assay: You can send us your bigWig files and we convert them to UCSC Genome Browser Tracks, that can be loaded from the single cell browser or can be loaded via the UCSC Genome Browser public hubs page."

IMPORTANT: Your response must be in this exact format with no other text:
SUBJECT: UCSC Cell browser for <summarize paper with 2-5 words> preprint
BODY:
[personalized email body here]
"""

    # Retry loop for rate limits
    for attempt in range(MAX_RETRIES):
        try:
            response = client.messages.create(
                model="claude-haiku-4-5",
                max_tokens=2048,
                messages=[{"role": "user", "content": prompt}]
            )
            break  # Success, exit retry loop
        except anthropic.RateLimitError as e:
            if attempt < MAX_RETRIES - 1:
                print(f"Rate limited, waiting {RETRY_DELAY}s before retry {attempt + 2}/{MAX_RETRIES}...")
                time.sleep(RETRY_DELAY)
            else:
                raise  # Re-raise on final attempt

    # Parse the response
    result = {"subject": "", "body": ""}
    for block in response.content:
        if block.type == "text":
            text = block.text
            # Extract subject
            subject_match = re.search(r'^SUBJECT:\s*(.+?)(?:\n|$)', text, re.MULTILINE)
            if subject_match:
                result["subject"] = subject_match.group(1).strip()
            # Extract body
            body_match = re.search(r'BODY:\s*\n(.*)', text, re.DOTALL)
            if body_match:
                result["body"] = body_match.group(1).strip()

    return result


def send_email_via_sendmail(to_addr: str, from_addr: str, subject: str, body: str) -> bool:
    """
    Send an email using the sendmail command.
    Returns True if successful, False otherwise.
    """
    email_content = f"""To: {to_addr}
From: {from_addr}
Subject: {subject}

{body}
"""
    try:
        proc = subprocess.Popen(
            ['/usr/sbin/sendmail', '-t'],
            stdin=subprocess.PIPE,
            stderr=subprocess.PIPE
        )
        _, stderr = proc.communicate(email_content.encode('utf-8'))
        if proc.returncode != 0:
            print(f"sendmail error: {stderr.decode('utf-8')}", file=sys.stderr)
            return False
        return True
    except FileNotFoundError:
        print("Error: sendmail not found at /usr/sbin/sendmail", file=sys.stderr)
        return False
    except Exception as e:
        print(f"Error sending email: {e}", file=sys.stderr)
        return False


def main():
    if len(sys.argv) < 2:
        print(f"Usage: {sys.argv[0]} <DOI_or_PMID> [email1] [email2] ...", file=sys.stderr)
        print(f"  Accepts either a bioRxiv/medRxiv DOI or a PubMed ID (PMID).", file=sys.stderr)
        print(f"  If email addresses are provided, skips the email search step.", file=sys.stderr)
        sys.exit(1)

    identifier = sys.argv[1].strip()
    provided_emails = [e.strip() for e in sys.argv[2:] if e.strip()]

    # Check for API key
    if not os.environ.get("ANTHROPIC_API_KEY"):
        print("Error: ANTHROPIC_API_KEY environment variable not set", file=sys.stderr)
        sys.exit(1)

    # Step 1: Get metadata (from PubMed for PMID, from bioRxiv for DOI)
    is_pmid_input = is_pmid(identifier)

    if is_pmid_input:
        print(f"PMID detected: {identifier}")
        print("Fetching metadata from PubMed...")
        try:
            record = get_pubmed_record(identifier)
        except Exception as e:
            print(f"Error: Could not fetch PubMed metadata: {e}", file=sys.stderr)
            sys.exit(1)
    else:
        print(f"DOI detected: {identifier}")
        print("Fetching metadata from bioRxiv/medRxiv...")
        try:
            record = get_biorxiv_record(identifier)
        except Exception as e:
            print(f"Error: Could not fetch bioRxiv metadata: {e}", file=sys.stderr)
            sys.exit(1)

    authors_str = record.get("authors", "")
    corr_inst = record.get("author_corresponding_institution")
    paper_title = record.get("title", "")

    if not authors_str:
        print("Error: No authors found in metadata", file=sys.stderr)
        sys.exit(1)

    if "author_corresponding" in record and record["author_corresponding"]:
        authors = [record["author_corresponding"]]
    else:
        authors = parse_authors(authors_str)

    print(f"Paper: {paper_title[:80]}...")
    print(f"Institution: {corr_inst or 'Unknown'}")
    if len(authors) >= 2:
        print(f"First author: {authors[0]}")
        print(f"Last author: {authors[-1]}")
    else:
        print(f"Author: {authors[0]}")

    # Step 2: Get email addresses
    if provided_emails:
        # Use provided email addresses
        print(f"\nUsing provided email addresses:")
        for email in provided_emails:
            print(f"  {email}")
        email_list = provided_emails
    elif is_pmid_input:
        # For PMIDs, check if we found an email in PubMed data
        pubmed_email = record.get("corresponding_email")
        if pubmed_email:
            print(f"\nFound corresponding author email in PubMed: {pubmed_email}")
            email_list = [pubmed_email]
        else:
            print("\nNo email address found in PubMed metadata.")
            print(f"Please rerun with an email address:")
            print(f"  {sys.argv[0]} {identifier} <email@example.com>")
            sys.exit(2)
    else:
        # For bioRxiv DOIs, search for emails with Claude
        print(f"Searching for emails...")
        try:
            emails = find_emails_with_claude(authors, corr_inst or "")

            if emails:
                target_count = min(2, len(authors))
                print(f"\nEmails found ({len(emails)}/{target_count} first/last authors):")
                for name, email in emails.items():
                    print(f"  {name}: {email}")
                email_list = list(emails.values())
            else:
                print("\nCould not find any email addresses.")
                sys.exit(2)

        except anthropic.APIError as e:
            print(f"Error calling Claude API: {e}", file=sys.stderr)
            sys.exit(1)

    # Step 3: Personalize email and send to all recipients
    if FROM_EMAIL == "your-email@example.com":
        print("\nError: Please edit FROM_EMAIL in the script before sending emails.", file=sys.stderr)
        sys.exit(1)

    print("\n" + "=" * 60)
    print("Personalizing email template with Claude...")
    print("=" * 60)

    # Use last author name for salutation (typically the PI)
    last_author_name = authors[-1] if authors else "Researcher"

    try:
        personalized = personalize_email_with_claude(EMAIL_TEMPLATE, record, last_author_name)

        if not personalized["subject"] or not personalized["body"]:
            print("\nError: Could not personalize email", file=sys.stderr)
            sys.exit(1)

    except anthropic.APIError as e:
        print(f"Error personalizing email: {e}", file=sys.stderr)
        sys.exit(1)

    # Collect all email addresses
    all_recipients = email_list.copy()
    all_recipients.append(FROM_EMAIL)
    all_recipients.append("cells@ucsc.edu")
    to_line = ", ".join(all_recipients)

    # Display the email for user approval
    print("\n" + "=" * 60)
    print(f"Email to: {to_line}")
    print("=" * 60)
    print(f"Subject: {personalized['subject']}")
    print("-" * 60)
    print(personalized['body'])
    print("=" * 60)

    # Prompt for confirmation
    response = input("Press Enter to send, 'q' to quit: ").strip().lower()

    if response == 'q':
        print("Quitting...")
        sys.exit(0)

    # Send the email to all recipients
    # XX ONLY FOR DEBUGGING - HARDCODED to my own address
    # to_line = "mhaeussl@ucsc.edu"
    if send_email_via_sendmail(to_line, FROM_EMAIL,
                              personalized['subject'], personalized['body']):
        print(f"Sent to {to_line}")
    else:
        print(f"Failed to send email", file=sys.stderr)
        sys.exit(1)

    print("\nDone.")


if __name__ == "__main__":
    main()
