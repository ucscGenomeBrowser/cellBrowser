#!/usr/bin/env python3
"""
Extract author emails from bioRxiv/medRxiv preprints or PubMed articles.

For bioRxiv/medRxiv DOIs: Gets metadata from bioRxiv API, then uses
Claude API with web search to find email addresses for authors.

For PubMed IDs (PMIDs): Gets metadata directly from PubMed. Uses the
corresponding author email if found in PubMed data, otherwise prompts
user to provide an email address.

Accepts either a DOI or a PMID (PubMed ID) as input.
"""
import sys
import os
import re
import subprocess
import time
import xml.etree.ElementTree as ET
import requests
from urllib.parse import quote

import anthropic

