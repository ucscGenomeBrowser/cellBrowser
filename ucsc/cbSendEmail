def fetch_biorxiv_papers(start_date=None, end_date=None, server="biorxiv"):
    """
    Fetch all papers posted in a date range from the bioRxiv or medRxiv API.
    If only start_date is given, fetches that single day.
    If neither is given, fetches today.
    Paginates through results (100 per page).
    Returns a list of paper record dicts.
    """
    if start_date is None:
        start_date = date.today().strftime("%Y-%m-%d")
    if end_date is None:
        end_date = start_date

    api_base = BIO_RXIV_API if server == "biorxiv" else MEDRXIV_API
    all_papers = []
    cursor = 0

    while True:
        url = f"{api_base}/{start_date}/{end_date}/{cursor}/json"
        for attempt in range(3):
            try:
                resp = requests.get(url, timeout=120)
                break
            except requests.exceptions.Timeout:
                if attempt < 2:
                    print(f"  Timeout fetching {server} (attempt {attempt+1}/3), retrying...",
                          file=sys.stderr)
                    time.sleep(5)
                else:
                    print(f"Warning: {server} API timed out after 3 attempts", file=sys.stderr)
                    return all_papers

        if resp.status_code != 200:
            print(f"Warning: {server} API returned status {resp.status_code}", file=sys.stderr)
            break

        data = resp.json()
        collection = data.get("collection", [])
        if not collection:
            break

        all_papers.extend(collection)
        total = data.get("messages", [{}])[0].get("total", 0)
        cursor += len(collection)

        if cursor >= int(total):
            break

        time.sleep(1)  # be polite to the API

    return all_papers


def fetch_pubmed_papers(start_date=None, end_date=None, query="single cell"):
    """
    Search PubMed for papers matching a query in a date range.
    Uses esearch to find PMIDs, then efetch to get metadata.
    Returns a list of paper dicts with keys: doi, title, abstract, authors, pmid.
    """
    if start_date is None:
        start_date = date.today().strftime("%Y/%m/%d")
    else:
        start_date = start_date.replace("-", "/")
    if end_date is None:
        end_date = start_date
    else:
        end_date = end_date.replace("-", "/")

    # Step 1: esearch — find PMIDs for preprints matching query
    search_term = query
    all_pmids = []
    retstart = 0
    retmax = 500

    while True:
        params = {
            "db": "pubmed",
            "term": search_term,
            "mindate": start_date,
            "maxdate": end_date,
            "datetype": "PDAT",
            "retmax": retmax,
            "retstart": retstart,
            "retmode": "json",
        }
        for attempt in range(3):
            try:
                resp = requests.get(NCBI_ESEARCH_URL, params=params, timeout=120)
                break
            except requests.exceptions.Timeout:
                if attempt < 2:
                    print(f"  Timeout on esearch (attempt {attempt+1}/3), retrying...",
                          file=sys.stderr)
                    time.sleep(5)
                else:
                    print("Warning: PubMed esearch timed out after 3 attempts", file=sys.stderr)
                    return []

        if resp.status_code != 200:
            print(f"Warning: PubMed esearch returned status {resp.status_code}", file=sys.stderr)
            break

        data = resp.json()
        result = data.get("esearchresult", {})
        id_list = result.get("idlist", [])
        total = int(result.get("count", 0))

        all_pmids.extend(id_list)
        retstart += len(id_list)

        if retstart >= total or not id_list:
            break
        time.sleep(0.4)  # NCBI asks for max 3 requests/second

    if not all_pmids:
        return []

    print(f"  Found {len(all_pmids)} PMIDs, fetching metadata...")

    # Step 2: efetch in batches of 200
    all_papers = []
    for i in range(0, len(all_pmids), 200):
        batch_ids = all_pmids[i:i+200]
        params = {
            "db": "pubmed",
            "id": ",".join(batch_ids),
            "retmode": "xml",
        }
        for attempt in range(3):
            try:
                resp = requests.get(NCBI_EFETCH_URL, params=params, timeout=120)
                break
            except requests.exceptions.Timeout:
                if attempt < 2:
                    print(f"  Timeout on efetch (attempt {attempt+1}/3), retrying...",
                          file=sys.stderr)
                    time.sleep(5)
                else:
                    print("Warning: PubMed efetch timed out after 3 attempts", file=sys.stderr)
                    return all_papers

        if resp.status_code != 200:
            print(f"Warning: PubMed efetch returned status {resp.status_code}", file=sys.stderr)
            continue

        root = ET.fromstring(resp.text)

        for article in root.findall(".//PubmedArticle"):
            # Title
            title_elem = article.find(".//ArticleTitle")
            title = title_elem.text if title_elem is not None and title_elem.text else ""

            # Abstract — may have multiple AbstractText elements
            abstract_parts = []
            for at in article.findall(".//AbstractText"):
                if at.text:
                    abstract_parts.append(at.text)
            abstract = " ".join(abstract_parts)

            # DOI
            doi = ""
            for aid in article.findall(".//ArticleId"):
                if aid.get("IdType") == "doi" and aid.text:
                    doi = aid.text
                    break
            if not doi:
                for eloc in article.findall(".//ELocationID"):
                    if eloc.get("EIdType") == "doi" and eloc.text:
                        doi = eloc.text
                        break

            # PMID
            pmid_elem = article.find(".//PMID")
            pmid = pmid_elem.text if pmid_elem is not None else ""

            # Authors
            author_names = []
            for author in article.findall(".//Author"):
                ln = author.find("LastName")
                fn = author.find("ForeName")
                if ln is not None and ln.text:
                    if fn is not None and fn.text:
                        author_names.append(f"{fn.text} {ln.text}")
                    else:
                        author_names.append(ln.text)
            authors_str = "; ".join(author_names)

            all_papers.append({
                "doi": doi,
                "title": title,
                "abstract": abstract,
                "authors": authors_str,
                "pmid": pmid,
            })

        if i + 200 < len(all_pmids):
            time.sleep(0.4)

    return all_papers


def prefilter_papers(papers, query="single cell"):
    """
    Pre-filter papers by checking if title or abstract contains any
    single-cell related keywords. Returns papers that match.
    """
    # Combine user query with built-in keywords
    keywords = list(SC_KEYWORDS)
    if query.lower() not in [k.lower() for k in keywords]:
        keywords.append(query.lower())

    matched = []
    for paper in papers:
        text = (paper.get("title", "") + " " + paper.get("abstract", "")).lower()
        for kw in keywords:
            if kw in text:
                matched.append(paper)
                break
    return matched


def classify_papers_with_claude(papers, batch_size=20):
    """
    Send papers to Claude in batches to classify which ones contain
    single-cell genomic data and what type.
    Returns a list of dicts: {doi, title, authors, data_types, has_new_data, summary}
    """
    client = anthropic.Anthropic()
    results = []

    for i in range(0, len(papers), batch_size):
        batch = papers[i:i + batch_size]
        papers_text = ""
        for idx, p in enumerate(batch):
            papers_text += f"\n--- PAPER {idx + 1} ---\n"
            papers_text += f"DOI: {p.get('doi', 'N/A')}\n"
            papers_text += f"Title: {p.get('title', 'N/A')}\n"
            papers_text += f"Authors: {p.get('authors', 'N/A')}\n"
            papers_text += f"Abstract: {p.get('abstract', 'N/A')}\n"

        prompt = f"""You are classifying bioRxiv preprints to find papers that generated new single-cell genomic datasets.

For each paper below, determine:
1. Does it contain NEW single-cell or single-nucleus genomic data (not re-analysis of public data)?
2. What type(s) of data: scRNA-seq, snRNA-seq, scATAC-seq, snATAC-seq, spatial (Visium/MERFISH/etc), multiome, lineage tracing, clone tracking, CITE-seq, or other_sc
3. A one-line summary of what the dataset is

Papers that are purely computational methods, reviews, re-analyses of existing public data, or not about single-cell genomics should be marked not_relevant.

{papers_text}

Respond ONLY with a JSON array. Each element must have these fields:
- "doi": the paper DOI
- "data_types": array of strings, a subset of  [scRNA-seq, snRNA-seq, scATAC-seq, snATAC-seq, spatial, multiome, lineage, clone CITE-seq, other_sc, not_relevant]
- "has_new_data": true if the paper generated new data, false if re-analysis or methods-only
- "summary": one-line description of the dataset/paper

Example:
[
  {{"doi": "10.1101/2026.01.01.000001", "data_types": ["scRNA-seq", "spatial"], "has_new_data": true, "summary": "Mouse brain cortex atlas with Visium and scRNA-seq"}},
  {{"doi": "10.1101/2026.01.01.000002", "data_types": ["not_relevant"], "has_new_data": false, "summary": "Benchmarking of clustering algorithms on public data"}}
]

Return ONLY the JSON array, no other text."""

        for attempt in range(MAX_RETRIES):
            try:
                response = client.messages.create(
                    model="claude-haiku-4-5-20251001",
                    max_tokens=4096,
                    messages=[{"role": "user", "content": prompt}]
                )
                break
            except anthropic.RateLimitError:
                if attempt < MAX_RETRIES - 1:
                    print(f"Rate limited, waiting {RETRY_DELAY}s before retry {attempt + 2}/{MAX_RETRIES}...")
                    time.sleep(RETRY_DELAY)
                else:
                    raise

        # Parse response
        for block in response.content:
            if block.type == "text":
                text = block.text.strip()
                # Strip markdown code fences if present
                if text.startswith("```"):
                    text = re.sub(r'^```(?:json)?\s*\n?', '', text)
                    text = re.sub(r'\n?```\s*$', '', text)
                try:
                    parsed = json.loads(text)
                    # Attach original paper metadata
                    doi_to_paper = {p["doi"]: p for p in batch}
                    for item in parsed:
                        paper = doi_to_paper.get(item["doi"], {})
                        item["title"] = paper.get("title", "")
                        item["authors"] = paper.get("authors", "")
                        results.append(item)
                except json.JSONDecodeError as e:
                    print(f"Warning: Could not parse Claude response: {e}", file=sys.stderr)
                    print(f"Response was: {text[:200]}...", file=sys.stderr)

        if i + batch_size < len(papers):
            time.sleep(1)

    return results


def is_pmid(identifier: str) -> bool:
    """
    Check if the identifier is a PMID (purely numeric) or a DOI.
    PMIDs are numeric strings, DOIs typically start with "10."
    """
    return identifier.isdigit()


def get_pubmed_record(pmid: str) -> dict:
    """
    Get paper metadata directly from PubMed using NCBI E-utilities API.
    Returns a dict with keys similar to bioRxiv API response:
    - title, abstract, authors, author_corresponding_institution, date, doi
    - author_corresponding (last author name)
    - corresponding_email (if found in affiliations)
    """
    params = {
        "db": "pubmed",
        "id": pmid,
        "retmode": "xml"
    }
    resp = requests.get(NCBI_EFETCH_URL, params=params, timeout=30)
    if resp.status_code != 200:
        raise RuntimeError(f"NCBI API returned status {resp.status_code}")

    root = ET.fromstring(resp.text)

    # Get title
    title_elem = root.find(".//ArticleTitle")
    title = title_elem.text if title_elem is not None else ""

    # Get abstract
    abstract_elem = root.find(".//AbstractText")
    abstract = abstract_elem.text if abstract_elem is not None else ""

    # Get DOI if available
    doi = ""
    for article_id in root.findall(".//ArticleId"):
        if article_id.get("IdType") == "doi":
            doi = article_id.text
            break
    if not doi:
        for eloc in root.findall(".//ELocationID"):
            if eloc.get("EIdType") == "doi":
                doi = eloc.text
                break

    # Get publication date
    pub_date = root.find(".//PubDate")
    date = ""
    if pub_date is not None:
        year = pub_date.find("Year")
        month = pub_date.find("Month")
        day = pub_date.find("Day")
        date_parts = []
        if year is not None:
            date_parts.append(year.text)
        if month is not None:
            date_parts.append(month.text)
        if day is not None:
            date_parts.append(day.text)
        date = "-".join(date_parts)

    # Get authors and affiliations
    authors_list = []
    corresponding_email = None
    institution = ""

    for author in root.findall(".//Author"):
        last_name = author.find("LastName")
        fore_name = author.find("ForeName")
        initials = author.find("Initials")

        if last_name is not None:
            if fore_name is not None:
                name = f"{fore_name.text} {last_name.text}"
            elif initials is not None:
                name = f"{initials.text} {last_name.text}"
            else:
                name = last_name.text
            authors_list.append(name)

        # Check affiliations for email addresses
        for affil in author.findall(".//AffiliationInfo/Affiliation"):
            if affil.text:
                # Extract email if present (often at end of affiliation)
                email_match = re.search(r'[\w.+-]+@[\w.-]+\.\w+', affil.text)
                if email_match:
                    corresponding_email = email_match.group(0)
                # Use first affiliation as institution
                if not institution:
                    # Remove email from institution string if present
                    inst_text = re.sub(r'\s*[\w.+-]+@[\w.-]+\.\w+\.?\s*$', '', affil.text)
                    institution = inst_text.strip().rstrip('.')

    # Format authors string like bioRxiv does: "Last1, F.; Last2, F. M."
    authors_str = "; ".join(authors_list)

    # Last author is typically the corresponding author
    author_corresponding = authors_list[-1] if authors_list else ""

    return {
        "title": title,
        "abstract": abstract,
        "authors": authors_str,
        "author_corresponding": author_corresponding,
        "author_corresponding_institution": institution,
        "date": date,
        "doi": doi,
        "corresponding_email": corresponding_email,
        "category": ""  # PubMed doesn't have this field
    }


def parse_authors(authors_str: str) -> list:
    """
    Parse the authors string from bioRxiv API into a list of full names.
    Input format: "Last1, F.; Last2, F. M.; Last3, F."
    Output: ["F. Last1", "F. M. Last2", "F. Last3"]
    """
    authors = []
    for author in authors_str.split(";"):
        author = author.strip()
        if not author:
            continue
        # Format is "LastName, Initials"
        if "," in author:
            parts = author.split(",", 1)
            last_name = parts[0].strip()
            initials = parts[1].strip() if len(parts) > 1 else ""
            # Reconstruct as "Initials LastName"
            if initials:
                authors.append(f"{initials} {last_name}")
            else:
                authors.append(last_name)
        else:
            authors.append(author)
    return authors


def get_crossref_record(doi: str) -> dict:
    """
    Fallback metadata source: resolve the DOI with CSL-JSON content negotiation
    (served by Crossref). Used when the bioRxiv/medRxiv API has not ingested a
    preprint yet -- their API lags the website by days for newly posted DOIs,
    including the new openRxiv "10.64898" prefix.

    Returns a dict in the same shape as get_biorxiv_record().
    """
    headers = {"Accept": "application/vnd.citationstyles.csl+json"}
    url = f"https://doi.org/{quote(doi, safe='/')}"
    resp = requests.get(url, headers=headers, timeout=30)
    if resp.status_code != 200:
        raise RuntimeError(f"DOI resolver returned status {resp.status_code}")
    data = resp.json()

    # Title may be a string or a single-element list
    title = data.get("title", "")
    if isinstance(title, list):
        title = title[0] if title else ""

    # Abstract is JATS/HTML markup (e.g. <jats:p>...); strip tags and the
    # leading "ABSTRACT" heading.
    abstract = data.get("abstract", "") or ""
    abstract = re.sub(r"<[^>]+>", " ", abstract)
    abstract = re.sub(r"\s+", " ", abstract).strip()
    abstract = re.sub(r"^abstract[:\s]*", "", abstract, flags=re.IGNORECASE)

    # Build a bioRxiv-style author string: "Family, G. I.; Family2, A. B."
    csl_authors = data.get("author", [])
    parts = []
    for a in csl_authors:
        family = (a.get("family") or "").strip()
        given = (a.get("given") or "").strip()
        if not family:
            # institutional/consortium author with only a "name" field
            name = (a.get("name") or "").strip()
            if name:
                parts.append(name)
            continue
        initials = " ".join(f"{tok[0]}." for tok in re.split(r"[\s.-]+", given) if tok)
        parts.append(f"{family}, {initials}" if initials else family)
    authors_str = "; ".join(parts)

    # CSL-JSON does not flag the corresponding author, so fall back to the last
    # author (typically the PI) -- the same name the bioRxiv API usually reports
    # and the one used for the email salutation.
    author_corresponding = ""
    corr_inst = ""
    if csl_authors:
        last = csl_authors[-1]
        family = (last.get("family") or "").strip()
        given = (last.get("given") or "").strip()
        author_corresponding = f"{given} {family}".strip() or (last.get("name") or "").strip()
        affil = last.get("affiliation") or []
        if affil:
            corr_inst = affil[0].get("name", "").strip()

    # Posted date -> zero-padded "YYYY-MM-DD" to match the bioRxiv API
    date_str = ""
    posted = data.get("posted") or data.get("published") or {}
    date_parts = posted.get("date-parts", [[]])
    if date_parts and date_parts[0]:
        p = date_parts[0]
        date_str = "-".join([str(p[0])] + [f"{int(x):02d}" for x in p[1:]])

    return {
        "title": title,
        "abstract": abstract,
        "authors": authors_str,
        "author_corresponding": author_corresponding,
        "author_corresponding_institution": corr_inst,
        "date": date_str,
        "doi": data.get("DOI", doi),
        "category": "",  # CSL-JSON has no bioRxiv subject collection
    }


def get_biorxiv_record(doi: str) -> dict:
    """
    Query the bioRxiv/medRxiv API for a single DOI and return the first record.
    Falls back to Crossref DOI metadata when the API has no record yet (the
    bioRxiv API can lag the website by several days for new preprints).
    """
    doi_encoded = quote(doi, safe="/")

    # Try bioRxiv first, then medRxiv
    for api_url in [BIO_RXIV_API, MEDRXIV_API]:
        url = f"{api_url}/{doi_encoded}/na/json"
        resp = requests.get(url, timeout=30)
        if resp.status_code == 200:
            data = resp.json()
            collection = data.get("collection", [])
            if collection:
                return collection[0]

    # Not in the bioRxiv API yet -- fall back to Crossref so recently posted
    # preprints (already live on the website) still work.
    print("  Not in bioRxiv API yet; falling back to Crossref DOI metadata...")
    return get_crossref_record(doi)


def find_emails_with_claude(authors: list, institution: str) -> dict:
    """
    Use Claude API with web search to find email addresses for first and last authors.
    Returns a dict mapping author names to their email addresses.
    Includes retry logic for rate limit errors.
    """
    client = anthropic.Anthropic()

    # Only search for first and last author
    if len(authors) >= 2:
        search_authors = [authors[0], authors[-1]]
    else:
        search_authors = authors

    authors_list = "\n".join(f"- {name}" for name in search_authors)

    prompt = f"""Find email addresses for these researchers at {institution}:

{authors_list}

Search the institution's website for faculty profile pages, lab websites, or directory listings that show their contact emails.

IMPORTANT: Your response must contain ONLY lines in this exact format, with no other text, explanations, or commentary:
AUTHOR_NAME: email@example.com

If you cannot find an email for an author, output:
AUTHOR_NAME: NOT_FOUND

Example correct output (use actual names and emails found):
John Smith: john.smith@university.edu
Jane Doe: NOT_FOUND

Do not include any other text besides lines in the above format.
"""

    # Retry loop for rate limits
    for attempt in range(MAX_RETRIES):
        try:
            response = client.messages.create(
                model="claude-sonnet-4-20250514",
                max_tokens=4096,
                tools=[{"type": "web_search_20250305", "name": "web_search", "max_uses": 10}],
                messages=[{"role": "user", "content": prompt}]
            )
            break  # Success, exit retry loop
        except anthropic.RateLimitError as e:
            if attempt < MAX_RETRIES - 1:
                print(f"Rate limited, waiting {RETRY_DELAY}s before retry {attempt + 2}/{MAX_RETRIES}...")
                time.sleep(RETRY_DELAY)
            else:
                raise  # Re-raise on final attempt

    # Parse the response to extract author-email pairs
    results = {}
    for block in response.content:
        if block.type == "text":
            text = block.text
            # Look for lines with "name: email" pattern
            for line in text.split("\n"):
                # Try to match "Name: email@domain.com" pattern
                # Name should be just letters, dots, spaces, hyphens (typical author name format)
                match = re.match(r'^[*-]?\s*([A-Za-z][A-Za-z.\-\s]{1,50}):\s*([\w.+-]+@[\w.-]+\.\w+|NOT_FOUND)\s*$', line.strip())
                if match:
                    name = match.group(1).strip()
                    email = match.group(2)
                    if email != "NOT_FOUND":
                        results[name] = email

    return results


def personalize_email_with_claude(template: str, record: dict, recipient_name: str, dataset_name: str = None) -> dict:
    """
    Use Claude to personalize the email template based on paper metadata.
    Returns dict with 'subject' and 'body' keys.
    Uses Haiku for speed and lower rate limits.
    Includes retry logic for rate limit errors.
    """
    client = anthropic.Anthropic()

    title = record.get("title", "")
    abstract = record.get("abstract", "")
    doi = record.get("doi", "")
    institution = record.get("author_corresponding_institution", "")
    authors = record.get("authors", "")
    category = record.get("category", "")
    date = record.get("date", "")

    if not dataset_name:
        path = "/hive/data/inside/cells/datasets"
        dsNames = [name for name in os.listdir(path) if os.path.isdir(os.path.join(path, name))]
        dsNameString = ",".join(dsNames)
    else:
        dsNameString = ""

    paper_url = f"https://doi.org/{doi}" if doi else ""

    if dataset_name:
        ds_instructions = f'Replace $DATASET_NAME with "{dataset_name}" exactly as given.'
    else:
        ds_instructions = f"""Replace $DATASET_NAME with a suggested shortname of the dataset. A good dataset shortname is shorter than 20 characters, ideally shorter, but can be a little longer if needed, e.g. < 25 letters. Never include the word "human", as most datasets are human. Never include "singlecell" or "sc" into the name, as all datasets are from single cells. The name usually includes the organ and the disease, the most important one of the paper,
or the cell line or condition that the paper focusses on. If the paper has mostly ATAC or spatial data, add -atac or -spatial to the dataset name. You can add the celltype if the paper focuses on a celltype. Abbreviate parts of the name to shorten the name if necessary. Only dashes are allowed in the name and lowercase characters. Example dataset names are: cortex-dev for a paper about the developing cortex, cortex-atac, for ATAC-seq on the cortex. Other examples: mouse-liver-scaring, ciona-regeneration, zebrafish-dev, hindbrain-dev, mouse-olig-dev. ms is usually multiple sclerosis, common acronyms for diseases are fine to use as acronyms. We do not usually abbreviate "organoid", so leave that as a word. Use an acronym if possible from the abstract, e.g. if the abstract mentions "HSC" as hematopoietic stem cells, then create a dataset with that acronym it, e.g. hsc-reprogram.
Try to use one or two parts separated by dashes, and not to use more than three parts separated by dashes. If the dataset is from mouse or another non-human species, prefix the dataset with the name of the species.

Here are example dataset names, as examples, do not use any of these literally, to avoid conflicts, but use them as inspiration: {dsNameString}

Do not use these words in dataset names:
    - homo
    - hetero
    - cells"""

    prompt = f"""You are helping to personalize an outreach email to a researcher about their preprint.

Here is information about the paper:
- Title: {title}
- Authors: {authors}
- Institution: {institution}
- Category: {category}
- Date: {date}
- DOI: {doi}
- Paper URL: {paper_url}
- Abstract: {abstract}

The recipient is: {recipient_name}
(Use only their first name in the greeting, e.g., "Dear John," not "Dear Dr. Smith,")

Here is the email template to personalize:
---
{template}
---

Please rewrite this email to make it specific to this paper. Reference specific aspects of their research (from the title/abstract) without praising the work, no sycophancy please. Keep the same overall structure and style of the template.

{ds_instructions}

If the abstract suggests that the paper contains ATAC-seq or Chip-Seq or "chromatin accessibility" data or other cis-regulatory data, replace the placeholder "UCSC Genome Browser tracks note for ATAC-seq datasets" with a text like the following: "Since your paper seems to include Chip-Seq or ATAC-seq data, note that we have support for this assay: You can send us your bigWig files and we convert them to UCSC Genome Browser Tracks, that can be loaded from the single cell browser or can be loaded via the UCSC Genome Browser public hubs page."

If the abstract suggests that the paper contains lineage tracing or clone tracking data, add a sentence like: "Your paper seems to include lineage tracing data, our website has special support for this, and can import from e.g. Monocle3 or URD."

IMPORTANT: Your response must be in this exact format with no other text:
DATASET_NAME: <the exact dataset shortname you used to replace $DATASET_NAME>
SUBJECT: UCSC Cell browser for <summarize paper with 2-5 words> preprint
BODY:
[personalized email body here]
"""

    # Retry loop for rate limits
    for attempt in range(MAX_RETRIES):
        try:
            response = client.messages.create(
                model="claude-haiku-4-5-20251001",
                max_tokens=2048,
                messages=[{"role": "user", "content": prompt}]
            )
            break  # Success, exit retry loop
        except anthropic.RateLimitError as e:
            if attempt < MAX_RETRIES - 1:
                print(f"Rate limited, waiting {RETRY_DELAY}s before retry {attempt + 2}/{MAX_RETRIES}...")
                time.sleep(RETRY_DELAY)
            else:
                raise  # Re-raise on final attempt

    # Parse the response
    result = {"subject": "", "body": "", "dataset_name": dataset_name or ""}
    for block in response.content:
        if block.type == "text":
            text = block.text
            # Extract dataset name
            ds_match = re.search(r'^DATASET_NAME:\s*(.+?)(?:\n|$)', text, re.MULTILINE)
            if ds_match:
                result["dataset_name"] = ds_match.group(1).strip()
            # Extract subject
            subject_match = re.search(r'^SUBJECT:\s*(.+?)(?:\n|$)', text, re.MULTILINE)
            if subject_match:
                result["subject"] = subject_match.group(1).strip()
            # Extract body
            body_match = re.search(r'BODY:\s*\n(.*)', text, re.DOTALL)
            if body_match:
                result["body"] = body_match.group(1).strip()

    # Fallback: pull the name out of the body if Claude omitted the DATASET_NAME line
    if not result["dataset_name"] and result["body"]:
        body_match = re.search(r'dataset name ["“]([a-z0-9-]+)["”]', result["body"])
        if body_match:
            result["dataset_name"] = body_match.group(1).strip()

    return result


def send_email_via_sendmail(to_addr: str, from_addr: str, subject: str, body: str) -> bool:
    """
    Send an email using the sendmail command.
    Returns True if successful, False otherwise.
    """
    email_content = f"""To: {to_addr}
From: {from_addr}
Subject: {subject}

{body}
"""
    try:
        proc = subprocess.Popen(
            ['/usr/sbin/sendmail', '-t'],
            stdin=subprocess.PIPE,
            stderr=subprocess.PIPE
        )
        _, stderr = proc.communicate(email_content.encode('utf-8'))
        if proc.returncode != 0:
            print(f"sendmail error: {stderr.decode('utf-8')}", file=sys.stderr)
            return False
        return True
    except FileNotFoundError:
        print("Error: sendmail not found at /usr/sbin/sendmail", file=sys.stderr)
        return False
    except Exception as e:
        print(f"Error sending email: {e}", file=sys.stderr)
        return False


def print_scan_results(classified):
    """Print classified scan results grouped by data type with copy-paste commands."""
    relevant = [p for p in classified if "not_relevant" not in p.get("data_types", [])]
    not_relevant = [p for p in classified if "not_relevant" in p.get("data_types", [])]

    # Collect all data types for grouping
    type_groups = {}
    for p in relevant:
        for dt in p.get("data_types", []):
            type_groups.setdefault(dt, []).append(p)

    # Print results
    print("\n" + "=" * 80)
    print(f"Results: {len(relevant)} relevant papers, {len(not_relevant)} not relevant")
    print("=" * 80)

    for dtype, papers in sorted(type_groups.items()):
        print(f"\n{dtype} ({len(papers)}):")
        for p in papers:
            new_tag = "[NEW DATA]" if p.get("has_new_data") else "[no new data]"
            doi = p.get("doi", "N/A")
            title = p.get("title", "N/A")
            if len(title) > 70:
                title = title[:67] + "..."
            print(f"  {doi}  {title}  {new_tag}")
            if p.get("summary"):
                print(f"    -> {p['summary']}")

    if not_relevant:
        print(f"\nnot_relevant ({len(not_relevant)}):")
        for p in not_relevant:
            doi = p.get("doi", "N/A")
            title = p.get("title", "N/A")
            if len(title) > 70:
                title = title[:67] + "..."
            print(f"  {doi}  {title}")

    # Print DOIs/PMIDs for easy copy-paste
    new_data_papers = [p for p in relevant if p.get("has_new_data")]
    if new_data_papers:
        print("\n" + "-" * 80)
        print("Papers with new data (copy-paste to send emails):")
        for p in new_data_papers:
            identifier = p.get("doi") or p.get("pmid", "")
            print(f"  cbSendEmail {identifier}")


def deduplicate_papers(papers):
    """Remove duplicate papers by DOI."""
    seen_dois = set()
    unique = []
    for p in papers:
        doi = p.get("doi", "")
        if doi and doi not in seen_dois:
            seen_dois.add(doi)
            unique.append(p)
        elif not doi:
            unique.append(p)
    if len(unique) < len(papers):
        print(f"  ({len(papers) - len(unique)} duplicates removed)")
    return unique


def classify_and_print(papers, query):
    """Pre-filter, classify with Claude, and print results. Shared by both scan modes."""
    filtered = prefilter_papers(papers, query)
    print(f"\n{len(filtered)} papers match single-cell keywords (from {len(papers)} total)")

    if not filtered:
        print("No papers matched the keyword filter.")
        return

    print(f"\nClassifying {len(filtered)} papers with Claude...")
    classified = classify_papers_with_claude(filtered)
    print_scan_results(classified)


def scan_biorxiv(start_date=None, end_date=None, query="single cell"):
    """
    Scan bioRxiv and medRxiv for single-cell genomic papers in a date range.
    """
    if start_date is None:
        start_date = date.today().strftime("%Y-%m-%d")
    if end_date is None:
        end_date = start_date

    if start_date == end_date:
        print(f"Scanning bioRxiv and medRxiv for {start_date}...")
    else:
        print(f"Scanning bioRxiv and medRxiv from {start_date} to {end_date}...")
    print(f"Pre-filter query: \"{query}\"")
    print()

    biorxiv_papers = fetch_biorxiv_papers(start_date, end_date, server="biorxiv")
    print(f"  bioRxiv: {len(biorxiv_papers)} papers")

    medrxiv_papers = fetch_biorxiv_papers(start_date, end_date, server="medrxiv")
    print(f"  medRxiv: {len(medrxiv_papers)} papers")

    all_papers = biorxiv_papers + medrxiv_papers
    if not all_papers:
        print("\nNo papers found for this date. Try a different date (bioRxiv may not have posted yet today).")
        return

    all_papers = deduplicate_papers(all_papers)
    classify_and_print(all_papers, query)


