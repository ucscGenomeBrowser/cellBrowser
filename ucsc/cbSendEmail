def load_emailed_emails(path=EMAILED_TSV):
    """Load the set of email addresses that have already been contacted."""
    emails = set()
    if not os.path.exists(path):
        return emails
    with open(path) as f:
        for line in f:
            line = line.strip()
            if not line or line.startswith("name\t"):
                continue
            parts = line.split("\t")
            if len(parts) >= 2:
                emails.add(parts[1].lower())
    return emails


