#! /usr/bin/env python3

import json, sys, argparse, os, time, glob
from datetime import timedelta, date

parser = argparse.ArgumentParser(
    formatter_class=argparse.RawDescriptionHelpFormatter,
    description="Update 'News' section in desc.conf. Also updates sitemap and list of datasets currently on the RR.")
parser.add_argument("-r","--run", action='store_true',
    help='run script to update news, rr datasets list, and sitemap.')
parser.add_argument("--newsOnly", action='store_true',
    help='only update news html')
parser.add_argument("-n","--now", action='store_true',
    help='set release date for current directory to Monday of this week (must be run from within the dataset directory)')
parser.add_argument("-p","--perDateDir", action='store', default="/hive/data/inside/cells/news/perDate/",
    help='where to find perDate news file')
parser.add_argument("-o","--newsOutDir", action='store', default="/hive/data/inside/cells/news/",
    help='where to output news file')
parser.add_argument("-d","--rrDatasetsOut", action='store', default="/hive/data/inside/cells/",
    help='directory where to find/output rr.datasets.txt')
parser.add_argument("-s","--sitemap", action='store', default="/hive/data/inside/cells/",
    help='directory where to output sitemap file')
parser.add_argument("-j","--dateJson", action='store', default="/hive/data/inside/cells/news/",
    help='directory where to output releaseDate.json file')
args = parser.parse_args()


def mondayBefore(aDate):
    """Returns the date of the Monday on or before a given date or date string."""
    if isinstance(aDate, str):
        aDate = date.fromisoformat(aDate)
    return aDate - timedelta(days=aDate.weekday())

def jsonListsToSets(o):
    """Converts lists in input JSON to sets."""
    if isinstance(o, list):
        return {jsonListsToSets(v) for v in o}
    elif isinstance(o, dict):
        return {k: jsonListsToSets(v) for k, v in o.items()}
    return o

def parseDateJson(dateJson):
    """Load releaseDate.json file."""
    with open(dateJson, 'r') as f:
        data = json.load(f)
    return jsonListsToSets(data)

def dumpToJson(data, outputFile):
    """Output data to named outputFile."""
    jsonOut = json.dumps(
        {k: list(v) if isinstance(v, set) else v for k, v in data.items()},
        indent=2, sort_keys=True)
    with open(outputFile, "w") as f:
        f.write(jsonOut)

def processDataset(dataset, rootDir):
    """Processes a single dataset and returns the shortname and a list of info about that dataset."""
    name = dataset["name"]
    # 'firstBuildTime' was added by Max in early 2022, so not all datasets have it
    try:
        lastmtime = dataset["firstBuildTime"]
    except KeyError:
        lastmtime = time.strftime('%Y-%m-%d', time.localtime(os.path.getmtime(os.path.join(rootDir, name, "exprMatrix.bin"))))
    monday = mondayBefore(lastmtime)
    short = dataset["shortLabel"]
    count = str(dataset["sampleCount"])
    return name, [short, count, monday]

def processCollection(collection, rootDir):
    """Processes a collection and returns a list of info about that collection.
       If it runs into a nested collection, will also process that."""
    collInfo = []
    name = collection["name"]
    with open(os.path.join(rootDir, name, "dataset.json"), "r") as f:
        cjson = json.load(f)
    for sub in cjson["datasets"]:
        if 'isCollection' in sub:
            collInfo += processCollection(sub, rootDir)
        else:
            subName, subList = processDataset(sub, rootDir)
            collInfo.append({subName: subList})
    return collInfo

def parseBetaDatasets():
    """Parses dataset.json for cells-beta to get a current list of datasets."""
    betaInfo = {}
    bdir = "/usr/local/apache/htdocs-cells-beta/"
    with open(os.path.join(bdir, "dataset.json"), "r") as f:
        cellsBeta = json.load(f)
    for dataset in cellsBeta["datasets"]:
        if "isCollection" in dataset:
            collectionInfo = processCollection(dataset, bdir)
            cname = dataset["name"]
            cshort = dataset["shortLabel"]
            oldDate = date.today()
            collCellCount = 0
            for d in collectionInfo:
                dname = list(d.keys())[0]
                info = d[dname]
                betaInfo[dname] = info
                collCellCount += int(info[1])
                if info[2] < oldDate:
                    oldDate = info[2]
            betaInfo[cname] = [cshort, str(collCellCount), oldDate]
        else:
            dname, bList = processDataset(dataset, bdir)
            betaInfo[dname] = bList
    return betaInfo

def combineNews():
    """Combines all of the perDate files into a single html file."""
    newsFiles = sorted(glob.glob(args.perDateDir + "*.html"), reverse=True)
    basicNews = os.path.join(args.newsOutDir, "basic.html")
    outName = os.path.join(args.newsOutDir, 'combined.html')
    with open(outName, 'w') as outfile:
        for fname in [basicNews] + newsFiles:
            with open(fname) as infile:
                outfile.write(infile.read())

def writeNewsHtml(toPrint, dateDir):
    """Writes one HTML file per release date listing all datasets released that day."""
    for day in toPrint:
        dateOut = dateDir + str(day) + ".html"
        dayNum, month, year = time.strftime('%d-%b-%Y', day.timetuple()).split("-")
        with open(dateOut, "w") as htmlOut:
            htmlOut.write("<p><b>" + month + " " + dayNum + ", " + year + "</b></p>\n")
            htmlOut.write("<p>New datasets:</p>\n<ul>\n")
            for line in toPrint[day]:
                htmlOut.write(line)
            htmlOut.write("</ul>\n")

def main():
    if not args.run:
        parser.print_help(sys.stderr)
        sys.exit(1)

    rrDatasetsPath = os.path.join(args.rrDatasetsOut, "rr.datasets.txt")
    dateJsonFile = os.path.join(args.dateJson, "releaseDate.json")
    sitemapPath = os.path.join(args.sitemap, "sitemap.cells.txt")

    # Load or initialize rr.datasets.txt
    if os.path.exists(rrDatasetsPath):
        with open(rrDatasetsPath) as f:
            oldNames = {line.strip().split("\t")[1] for line in f if not line.startswith("#")}
    else:
        oldNames = set()
        with open(rrDatasetsPath, "w") as f:
            f.write("#release_date\tdataset_shortname\tdataset_label\tcell_count\n")

    # Load or initialize releaseDate.json
    if os.path.exists(dateJsonFile):
        dateDict = parseDateJson(dateJsonFile)
    else:
        dateDict = {}

    # Build inverted index for O(1) dataset->date lookups
    nameToDate = {name: d for d, names in dateDict.items() for name in names}

    # Load or initialize sitemap
    if os.path.exists(sitemapPath):
        with open(sitemapPath) as f:
            sitemapSet = set(f)
    else:
        sitemapSet = set()
        open(sitemapPath, "w").close()

    betaInfo = parseBetaDatasets()
    toPrint = {}
    newSitemapUrls = []
    currentDataset = os.path.basename(os.getcwd())

    with open(rrDatasetsPath, "a") as rrDatasets:
        for entry, info in betaInfo.items():
            label, count, buildDate = info

            if entry == currentDataset and args.now:
                day = mondayBefore(date.today())
                if entry in nameToDate:
                    dateDict[nameToDate[entry]].discard(entry)
            elif entry in nameToDate:
                day = date.fromisoformat(nameToDate[entry])
            else:
                day = buildDate

            if not args.newsOnly and entry not in oldNames:
                rrDatasets.write(f"{day}\t{entry}\t{label}\t{count}\n")

            # Skip collection members (contain '/') for sitemap and news
            if "/" not in entry:
                dateDict.setdefault(str(day), set()).add(entry)
                if not args.newsOnly:
                    urlline = f"https://{entry}.cells.ucsc.edu\n"
                    if urlline not in sitemapSet:
                        newSitemapUrls.append(urlline)
                        sitemapSet.add(urlline)
                outLine = f"  <li><a href='?ds={entry}' target='_blank'>{label}</a>\n"
                toPrint.setdefault(day, []).append(outLine)

    if not args.newsOnly and newSitemapUrls:
        with open(sitemapPath, "a") as f:
            f.writelines(newSitemapUrls)

    dumpToJson(dateDict, dateJsonFile)
    writeNewsHtml(toPrint, args.perDateDir)
    combineNews()

if __name__ == "__main__":
    main()
