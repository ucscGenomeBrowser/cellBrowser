"""
Extract author emails from bioRxiv/medRxiv preprints.

Gets author names and institution from bioRxiv API, then uses
Claude API with web search to find email addresses for all authors.
"""
import sys
import os
import re
import subprocess
import time
import requests
from urllib.parse import quote

import anthropic

# Retry settings for rate limits
MAX_RETRIES = 3
RETRY_DELAY = 65  # seconds to wait before retrying (rate limit is per minute)

