#! /usr/bin/env python3

import sys, argparse, json, os
from collections import OrderedDict
from os.path import join, basename, dirname, exists, realpath
from pathlib import Path

# allow importing from the cellbrowser package alongside this script
_scriptDir = dirname(realpath(__file__))
sys.path.insert(0, join(_scriptDir, '..', 'src', 'cbPyLib'))

def readLines(lines, fname):
    " recursively read lines from fname, understands lines like #include 'filename.conf' "
    for line in open(fname):
        line = line.rstrip("\r\n")
        if line.startswith("#include"):
            newFname = line.split(" ", 1)[1].strip('"').strip("'")
            lines.extend(readLines(lines, newFname))
        else:
            lines.append(line)
    return lines

def loadConfig(fname):
    """ parse python in fname and return variables as dictionary. """
    conf = OrderedDict()
    g = {}
    g["fileBase"] = basename(fname).split('.')[0]
    g["dirName"] = basename(dirname(fname))
    lines = readLines([], fname)
    exec("\n".join(lines), g, conf)
    return conf

def computeValue(rawStr, dataType):
    " convert a raw TSV string into a typed Python value "
    if dataType == "list":
        return [x.strip() for x in rawStr.split(',')]
    elif dataType == "str":
        return rawStr
    elif dataType == "int":
        return int(rawStr)
    elif dataType == "float":
        return float(rawStr)
    else:
        raise ValueError("Unknown dataType after pipe character: %s" % dataType)

def valueToConfStr(value, dataType):
    " convert a Python value to a conf file representation "
    if dataType == "list":
        return str(value)
    else:
        return repr(value)

def buildNewConf(confPath, updates):
    """
    Rewrite conf file content applying updates (dict of tag -> (value, confStr)).
    Tags already in the file are updated in place; new tags are appended.
    Returns the new content as a string.
    """
    outLines = []
    handled = set()
    removeTriplets = False

    for line in open(confPath):
        if removeTriplets:
            if '"""' in line:
                removeTriplets = False
            continue
        parts = line.strip().split("=", 1)
        confTag = parts[0].strip()
        if confTag in updates:
            value, confStr = updates[confTag]
            outLines.append(confTag + "=" + confStr + "\n")
            handled.add(confTag)
            if len(parts) > 1 and '"""' in parts[1]:
                removeTriplets = True
        else:
            outLines.append(line if line.endswith('\n') else line + '\n')

    # append tags not already present in the conf
    for tag, (value, confStr) in updates.items():
        if tag not in handled:
            outLines.append(tag + "=" + confStr + "\n")

    return "".join(outLines)

def processDataset(dname, updates, confPath, jsonPath, updateJson):
    """
    Apply updates to confPath and (if updateJson) jsonPath using atomic temp-file
    replacement so both files are always consistent.

    updates: dict of tagName -> (python_value, conf_str)
    """
    if not updates:
        return

    newConfContent = buildNewConf(confPath, updates)

    newJsonContent = None
    if updateJson:
        if exists(jsonPath):
            with open(jsonPath) as f:
                jsonData = json.load(f)
            for tag, (value, _) in updates.items():
                jsonData[tag] = value
            newJsonContent = json.dumps(jsonData, indent=2)
        else:
            print("  warning: %s not found, skipping JSON update" % jsonPath)

    # write both temp files before replacing either (minimises drift window)
    confTmp = confPath + ".tmp"
    jsonTmp = jsonPath + ".tmp" if newJsonContent is not None else None
    try:
        with open(confTmp, 'w') as f:
            f.write(newConfContent)
        if jsonTmp:
            with open(jsonTmp, 'w') as f:
                f.write(newJsonContent)
    except Exception as e:
        for tmp in [confTmp, jsonTmp]:
            if tmp and exists(tmp):
                os.unlink(tmp)
        raise

    os.replace(confTmp, confPath)
    if jsonTmp:
        os.replace(jsonTmp, jsonPath)

# ---- argument parsing ----

parser = argparse.ArgumentParser(
    formatter_class=argparse.RawDescriptionHelpFormatter,
    description="""\
Add/update tag values for a list of datasets.

Requires a tab-separated file with a header line; the first column is the
dataset name, subsequent columns are tag names to add or update. Tag names
may include a type suffix after a pipe character (e.g. 'unit|str'); valid
types are list (default), str, int, float.

By default the script also updates the corresponding built JSON file
(dataset.json or desc.json) so changes take effect immediately without
re-running cbBuild. Both the conf file and the JSON file are written via
temp files to avoid drift if the script is interrupted.
""")
parser.add_argument('datasetFile',
    help='TSV file with dataset names in column 1 and tag values in subsequent columns')
parser.add_argument("-i", "--inDir", default="/hive/data/inside/cells/datasets",
    help='directory containing dataset source files (default: /hive/data/inside/cells/datasets)')
parser.add_argument("-o", "--outDir", default="/usr/local/apache/htdocs-cells",
    help='directory containing built dataset JSON files (default: /usr/local/apache/htdocs-cells)')
parser.add_argument('-d', '--descConf', action='store_true',
    help='edit desc.conf / desc.json instead of cellbrowser.conf / dataset.json')
parser.add_argument('--no-json', action='store_true', dest='noJson',
    help='update conf files only; do not touch JSON files')
parser.add_argument('--rebuild-search', action='store_true', dest='rebuildSearch',
    help='rebuild search.json in --outDir after all updates are applied')

args = parser.parse_args()

if Path(args.datasetFile).suffix == ".csv":
    print("datasetFile must be TSV, not CSV")
    sys.exit(1)

confFname = "desc.conf" if args.descConf else "cellbrowser.conf"
jsonFname = "desc.json" if args.descConf else "dataset.json"
updateJson = not args.noJson

dfh = open(args.datasetFile)
header = dfh.readline().rstrip().split('\t')
headerNoType = [x.split("|")[0] for x in header]

for line in dfh:
    splitLine = line.rstrip('\n').split('\t')
    dname = splitLine[0]
    print("processing:", dname)

    confPath = join(args.inDir, dname, confFname)
    jsonPath = join(args.outDir, dname, jsonFname)

    if not exists(confPath):
        print("  warning: %s not found, skipping" % confPath)
        continue

    # build updates dict for this dataset
    updates = {}
    for tag in header:
        if tag == "dataset":
            continue
        dataType = "list"
        tagName = tag
        if "|" in tag:
            tagName, dataType = tag.split("|")

        n = headerNoType.index(tagName)
        rawVal = splitLine[n] if n < len(splitLine) else ''
        if rawVal == '':
            continue

        value = computeValue(rawVal, dataType)
        updates[tagName] = (value, valueToConfStr(value, dataType))

    processDataset(dname, updates, confPath, jsonPath, updateJson)

if updateJson and args.rebuildSearch:
    from cellbrowser.cellbrowser import buildSearchJson
    print("\nRebuilding search.json...")
    buildSearchJson(args.outDir)
elif updateJson:
    print("\nNote: search.json not updated. Pass --rebuild-search to refresh search results.")
